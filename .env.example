# Copy to .env and adjust. .env is gitignored, so your values survive a git pull.

# tModLoader version to build. Must be a real release tag (note the zero-padded month):
#   https://github.com/tModLoader/tModLoader/releases
TML_VERSION=v2026.03.3.0

# Host port to publish the server on. The container always listens on 7777.
TML_PORT=7777

# Timezone for the backup schedule.
TZ=Australia/Melbourne
